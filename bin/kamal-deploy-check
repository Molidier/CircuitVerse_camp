#!/usr/bin/env bash
# Check that required env vars for Kamal deploy are set.
# Usage: ./bin/kamal-deploy-check
# Or: source deploy.env 2>/dev/null; ./bin/kamal-deploy-check

set -e
missing=()

check() {
  if [[ -z "${!1}" ]]; then
    missing+=("$1")
  fi
}

check SERVER_IP
check POSTGRES_URL
check SECRET_KEY_BASE

if [[ ${#missing[@]} -gt 0 ]]; then
  echo "Missing required environment variables for Kamal deploy:"
  printf '  - %s\n' "${missing[@]}"
  echo ""
  echo "Set them in GitHub Actions secrets or in a .env file (see deploy.env.example)."
  exit 1
fi

if [[ "${POSTGRES_URL}" =~ @(localhost|127\.0\.0\.1|172\.17\.0\.1)(:|/) ]]; then
  echo "POSTGRES_URL points to ${BASH_REMATCH[1]}, which is not reachable from Kamal app containers."
  echo "If PostgreSQL runs on the same Docker host, use host.docker.internal in POSTGRES_URL instead."
  echo "Example: postgres://user:password@host.docker.internal:5432/circuitverse_production"
  exit 1
fi

echo "All required Kamal deploy variables are set."
echo "Optional: RAILS_MASTER_KEY, RECAPTCHA_SITE_KEY, RECAPTCHA_SECRET_KEY, TRAEFIK_HOST, AWS_S3_*, BUGSNAG_API_KEY"
exit 0
