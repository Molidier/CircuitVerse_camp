# Kamal deploy – environment variables
# Copy to .env or set in GitHub Actions secrets. Used for Option B (Kamal) deploy.
# Do NOT commit real values. This file is for reference only.

# ---- Required ----
SERVER_IP=your.server.ip.or.hostname
POSTGRES_URL=postgres://user:password@host:5432/circuitverse_production
SECRET_KEY_BASE=output_of_rails_secret

# ---- Required for GitHub Actions (SSH) ----
# SSH_PRIVATE_KEY = full PEM content (add as repo secret, do not put in .env)

# ---- Recommended ----
# Domain for Traefik (HTTPS). If unset, defaults to staging.circuitverse.org.
TRAEFIK_HOST=circuitverse.yourschool.edu

# ---- Optional (set in config/deploy.yml or here) ----
# RAILS_MASTER_KEY=
# RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=
# AWS_S3_ACCESS_KEY_ID=
# AWS_S3_SECRET_ACCESS_KEY=
# BUGSNAG_API_KEY=

# ---- For local Kamal deploy only (GHCR) ----
# KAMAL_IMAGE=owner/repo   # lowercase, e.g. myorg/circuitverse_camp
# KAMAL_REGISTRY_USERNAME=your_github_username
# KAMAL_GHCR_REGISTRY_PASSWORD=github_pat_or_token_with_read_packages
