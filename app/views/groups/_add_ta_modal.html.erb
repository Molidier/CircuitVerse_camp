<div id="add-ta-to-modal" class="modal fade" role="dialog">
  <div class="modal-dialog primary-modal-dialog">
    <div class="modal-content">
      <div class="modal-header primary-modal-header">
        <h4 class="modal-title"><%= t("groups.show.add_tas_btn") %></h4>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="close"></button>
      </div>
      <div class="modal-body">
        <p><%= t("groups.add_member_description") %></p>
        <p><%= t("groups.add_ta_description_html") %></p>
        <%= form_with(model: group_member, local: true) do |form| %>
          <% if group_member.errors.any? %>
            <div class="error-message">
              <ul>
                <% group_member.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
          <div class="field">
            <%= form.hidden_field :group_id, id: :group_member_group_id_ta %>
          </div>
          <div class="field">
            <%= form.hidden_field :mentor, value: false %>
          </div>
          <div class="field">
            <%= form.hidden_field :ta, value: true %>
          </div>
          <div class="mb-3 d-flex flex-column">
            <%= form.label :emails %>
            <%= form.select :emails, [], {}, { class: "form-select", id: "group_ta_emails", multiple: true } %>
          </div>
          <div class="modal-footer">
            <%= form.submit t("groups.show.add_tas_btn"), class: "btn primary-button", id: "add-ta-button" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
